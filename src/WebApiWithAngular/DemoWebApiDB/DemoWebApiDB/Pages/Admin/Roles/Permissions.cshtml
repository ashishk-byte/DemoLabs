@page
@model DemoWebApiDB.Pages.Admin.Roles.PermissionsModel

<div class="container">

    <h4 class="mb-4">Manage Permissions for the ROLE: @Model.Role.Name</h4>

    <form method="post">
        <div class="row row-cols-1 row-cols-md-3 g-4 mb-4">

            @foreach (var group in Model.Permissions.GroupBy(p => p.Group))
            {

                <div class="col">
                    <div class="card h-100">

                        <div class="card-header bg-secondary text-white">
                            <strong>@group.Key</strong>
                        </div>

                        <div class="card-body">

                            @foreach (var permission in group)
                            {
                                <div class="form-check form-switch">

                                    <input class="form-check-input" type="checkbox" role="switch" 
                                           name="SelectedPermissions" id="@permission.Id"
                                           value="@permission.Id"
                                           checked="@(permission.IsAssigned)" />

                                    <label class="form-check-label" for="@permission.Id">
                                        @permission.DisplayName
                                    </label>

                                </div>
                            }

                        </div>      <!-- END: card-body -->

                    </div>      <!-- END: card -->
                </div>      <!-- END: col -->

            }           @* END: foreach loop *@

        </div>
    
        <button type="submit" class="btn btn-primary">
            Save Permissions
        </button>
        <a asp-page="Index" class="btn btn-outline-primary">
            Cancel
        </a>

    </form>

</div>

