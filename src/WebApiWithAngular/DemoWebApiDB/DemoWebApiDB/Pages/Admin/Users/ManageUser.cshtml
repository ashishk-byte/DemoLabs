@page
@model DemoWebApiDB.Pages.Admin.Users.ManageUserModel

@{
    bool isEditMode = !string.IsNullOrEmpty(Model.UserViewModel.Id);
}

<div class="container">

    @if(isEditMode)
    {
        <h4 class="mb-4">Edit existing user</h4>
    }
    else
    {
        <h4 class="mb-4">Add new user</h4>
    }

    <form method="post">

        <div class="alert alert-danger d-flex align-items-center mb-4 pb-0" role="alert"
             asp-validation-summary="ModelOnly"></div>

        <div class="row">

            <div class="col-8">

                <input type="hidden" asp-for="UserViewModel.Id" />

                <div class="mb-3">
                    <label class="form-label" asp-for="UserViewModel.FullName"></label>
                    <input class="form-control" asp-for="UserViewModel.FullName" />
                    <span asp-validation-for="UserViewModel.FullName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label" asp-for="UserViewModel.Email"></label>
                    <input class="form-control" asp-for="UserViewModel.Email" />
                    <span asp-validation-for="UserViewModel.Email" class="text-danger"></span>
                </div>

                @if (!isEditMode)
                {
                    <div class="mb-3">
                        <label class="form-label" asp-for="UserViewModel.Password"></label>
                        <input class="form-control" asp-for="UserViewModel.Password" type="password" />
                        <span asp-validation-for="UserViewModel.Password" class="text-danger"></span>
                    </div>
                }
            </div>

            <div class="col-1"></div>

            <div class="col-3">

                <div class="card">
                    <div class="card-header bg-secondary text-white">
                        <strong>Application Roles</strong>
                    </div>

                    <div class="card-body">
 
                        @*
                           IMPORTANT:
                           Using a FOR loop instead of FOREACH allows Razor
                           to correctly bind the List<RoleItem> during POST.
                        *@
                        @for (int i = 0; i < Model.UserViewModel.SelectedRoles.Count; i++)
                        {
                            <div class="form-check">

                                <input class="form-check-input"
                                       asp-for="UserViewModel.SelectedRoles[i].Selected" />

                                <input type="hidden"
                                       asp-for="UserViewModel.SelectedRoles[i].RoleName" />

                                <label class="form-check-label">
                                    @Model.UserViewModel.SelectedRoles[i].RoleName
                                </label>

                            </div>
                        }

                    </div>
                </div>

            </div>

        </div>

        <p class="mt-4">
            <button type="submit" class="btn btn-primary">
                Save
            </button>
            <a asp-page="Index" class="btn btn-outline-primary">
                Cancel
            </a>
        </p>

    </form>
</div>


@section Scripts
{
    @* Needed for Client-Side Validation *@
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
}
